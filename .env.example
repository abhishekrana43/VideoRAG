# ==========================================================
# Video-RAG Environment Variables
# ==========================================================
# Copy this file to .env
# Fill in the required API keys before running the project.
#
# cp .env.example .env
# ==========================================================


# ==========================================================
# LLM Configuration
# ==========================================================

# Provider:
# Supported: mistral | openai | groq
LLM_PROVIDER=mistral

# Mistral API Key
MISTRAL_API_KEY=your_mistral_api_key

# Model name
MISTRAL_MODEL=mistral-large-latest


# ==========================================================
# Embedding Model
# ==========================================================

# HuggingFace embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# ==========================================================
# Whisper Configuration
# ==========================================================

# Whisper model
# tiny
# base
# small
# medium
# large
WHISPER_MODEL=base

# Device
# cpu
# cuda
WHISPER_DEVICE=cpu


# ==========================================================
# Sarvam AI (Hindi Transcription)
# ==========================================================

SARVAM_API_KEY=your_sarvam_api_key


# ==========================================================
# Vector Database
# ==========================================================

# chroma
# faiss
VECTOR_STORE=chroma

# Folder where vectors will be stored
CHROMA_DB_DIR=./vectorstore

# Chunk settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200


# ==========================================================
# Retrieval
# ==========================================================

TOP_K=5


# ==========================================================
# Application
# ==========================================================

APP_NAME=Video-RAG

LOG_LEVEL=INFO

CACHE_DIR=./cache

TEMP_DIR=./temp

UPLOAD_DIR=./uploads


# ==========================================================
# YouTube Download
# ==========================================================

# Maximum allowed video size (MB)
MAX_VIDEO_SIZE_MB=500

# Maximum duration (minutes)
MAX_VIDEO_DURATION_MIN=180


# ==========================================================
# Supported Languages
# ==========================================================

DEFAULT_LANGUAGE=en

SUPPORTED_LANGUAGES=en,hi


# ==========================================================
# Optional OpenAI Configuration
# ==========================================================

OPENAI_API_KEY=

OPENAI_MODEL=gpt-4.1-mini


# ==========================================================
# Optional Groq Configuration
# ==========================================================

GROQ_API_KEY=

GROQ_MODEL=llama-3.3-70b-versatile


# ==========================================================
# Streamlit
# ==========================================================

STREAMLIT_SERVER_PORT=8501

STREAMLIT_SERVER_ADDRESS=localhost


# ==========================================================
# Development
# ==========================================================

ENVIRONMENT=development

DEBUG=True